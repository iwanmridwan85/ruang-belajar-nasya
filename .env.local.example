# Salin file ini menjadi ".env.local" lalu isi API key Claude Bapak.
# Cara: di Terminal jalankan  ->  cp .env.local.example .env.local
# lalu buka .env.local, tempel key setelah tanda "=".

# API key dari https://console.anthropic.com  (formatnya diawali "sk-ant-...")
ANTHROPIC_API_KEY=

# (opsional) Model yang dipakai guru AI. Boleh dibiarkan.
# Pilihan hemat & cepat: claude-haiku-4-5   | Lebih pintar: claude-sonnet-5
ANTHROPIC_MODEL=claude-sonnet-5
